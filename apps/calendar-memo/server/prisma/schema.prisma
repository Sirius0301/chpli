generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 用户表
model User {
  id           String    @id @default(uuid())
  email        String?   @unique
  phone        String?   @unique
  password     String
  name         String
  avatar       String?
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // 关联 - 级联删除：用户删除时删除其所有标签和备忘录
  memos        Memo[]
  tags         Tag[]
  verificationCodes VerificationCode[]

  @@index([email])
  @@index([phone])
  @@map("users")
}

// 验证码表
model VerificationCode {
  id        String   @id @default(uuid())
  email     String?
  phone     String?
  code      String   @db.VarChar(6)
  type      CodeType
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  usedAt    DateTime?
  createdAt DateTime @default(now())
  
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email, type, createdAt])
  @@index([phone, type, createdAt])
  @@map("verification_codes")
}

enum CodeType {
  REGISTER
  RESET_PASSWORD
  CHANGE_PASSWORD
}

// 备忘录表
model Memo {
  id            String       @id @default(uuid())
  title         String
  description   String?
  location      String?
  date          String       // YYYY-MM-DD
  completed     Boolean      @default(false)
  repeatType    RepeatType   @default(NONE)
  repeatEndType RepeatEndType @default(NEVER)
  repeatEndDate String?
  priority      Priority?
  imageUrl      String?
  
  // 关联用户 - 级联删除
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // 关联标签 - 解除关联不删除
  tags          Tag[]
  
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([userId, date])
  @@index([userId, completed])
  @@map("memos")
}

// 标签表 - 用户私有化
model Tag {
  id        String   @id @default(uuid())
  name      String
  color     String?
  
  // 关联用户 - 级联删除
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // 关联备忘录 - 删除标签时解除关联，不删备忘录
  memos     Memo[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 同一用户标签名唯一
  @@unique([userId, name])
  @@index([userId])
  @@map("tags")
}

enum RepeatType {
  NONE
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  SEMIANNUAL
  YEARLY
}

enum RepeatEndType {
  NEVER
  ONDATE
}

enum Priority {
  HIGH
  MEDIUM
  LOW
}
