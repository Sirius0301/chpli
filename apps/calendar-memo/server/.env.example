# ==========================================
# Calendar Memo Server - PostgreSQL 环境配置
# ==========================================

# 服务器配置
NODE_ENV=development
PORT=3001

# PostgreSQL 数据库连接
# 本地开发使用 Docker: docker-compose up -d postgres
DATABASE_URL="postgresql://chpli:chpli_secret@localhost:5432/chpli?schema=public"

# JWT 配置
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d

# 腾讯云 SES/SMS 配置（可选）
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
SMS_SIGN_NAME=
SMS_TEMPLATE_ID=
SES_FROM_EMAIL=
