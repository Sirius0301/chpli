# ==========================================
# Calendar Memo Server 环境变量配置
# ==========================================

# 服务器配置
NODE_ENV=development
PORT=3001

# 数据库配置 (Prisma + PostgreSQL)
# 格式: postgresql://user:password@host:port/database
DATABASE_URL="postgresql://chpli:chpli_secret@localhost:5432/chpli?schema=calendar_memo"

# JWT 配置
# 生产环境必须使用强密钥，可通过: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d

# 腾讯云 SES/SMS 配置（生产环境必需）
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
SMS_SIGN_NAME=您的短信签名
SMS_TEMPLATE_ID=您的短信模板ID
SES_FROM_EMAIL=noreply@yourdomain.com
