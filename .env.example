# ==========================================
# Chpli Monorepo 环境变量配置
# ==========================================

# ==========================================
# 基础配置
# ==========================================
NODE_ENV=development

# ==========================================
# PostgreSQL 数据库配置
# ==========================================
POSTGRES_USER=chpli
POSTGRES_PASSWORD=chpli_secret
POSTGRES_DB=chpli
POSTGRES_PORT=5432

# Prisma 数据库连接 URL
# 格式: postgresql://user:password@host:port/database?schema=schema_name
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}?schema=calendar_memo"

# ==========================================
# Calendar Memo - Web 前端配置
# ==========================================
CALENDAR_MEMO_WEB_PORT=5173

# ==========================================
# Calendar Memo - Server 后端配置
# ==========================================
CALENDAR_MEMO_SERVER_PORT=3001

# JWT 认证配置
# 生产环境请使用强密钥: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d

# ==========================================
# 腾讯云 SES/SMS 服务配置（生产环境必需）
# ==========================================
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
SMS_SIGN_NAME=您的短信签名
SMS_TEMPLATE_ID=您的短信模板ID
SES_FROM_EMAIL=noreply@yourdomain.com
