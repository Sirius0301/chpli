{
  "name": "chpli",
  "version": "1.0.0",
  "description": "Chpli Monorepo - A collection of personal productivity applications",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm run --parallel dev",
    "dev:calendar": "pnpm --filter '@chpli/calendar-memo-*' --parallel dev",
    "build": "pnpm -r build",
    "start": "pnpm --filter @chpli/calendar-memo start",
    "lint": "pnpm -r lint",
    "type-check": "pnpm -r type-check",
    "db:up": "docker-compose up -d postgres",
    "db:down": "docker-compose down",
    "db:logs": "docker-compose logs -f postgres"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
